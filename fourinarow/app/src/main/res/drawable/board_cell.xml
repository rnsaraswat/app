<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Blue board -->
    <item>
        <shape>
            <solid android:color="#1E3A8A"/>
        </shape>
    </item>

    <!-- Hole (white circle look) -->
    <item
        android:left="6dp"
        android:top="6dp"
        android:right="6dp"
        android:bottom="6dp">

        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/>
        </shape>

    </item>

</layer-list>